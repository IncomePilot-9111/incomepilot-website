# ─── Supabase ────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values from:
# Supabase Dashboard -> Project Settings -> API
#
# NEXT_PUBLIC_ vars are safe to expose in the browser.
# Row-Level Security policies protect your data.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Site URL ────────────────────────────────────────────────────────────────
# Required for correct email redirect URLs in production.
# Set in Vercel environment variables (not .env.local) for deployments.
# Must exactly match what you set in Supabase Dashboard -> Auth -> URL Configuration

# NEXT_PUBLIC_SITE_URL=https://valkoda.app

# ─── App deep-link scheme ────────────────────────────────────────────────────
# Custom URL scheme registered in the Flutter app (Info.plist / AndroidManifest).
# Default: valkoda -> opens valkoda://
# Only change if you update the scheme in the Flutter project.

# NEXT_PUBLIC_APP_SCHEME=valkoda

# ─── Supabase service role (SERVER ONLY — never NEXT_PUBLIC_) ────────────────
# Supabase Dashboard -> Project Settings -> API -> service_role secret
# Used by /api/premium/status and /api/revenuecat/webhook to bypass RLS
# for upserts into premium_entitlements. NEVER expose to the browser.

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── RevenueCat (SERVER ONLY — never NEXT_PUBLIC_) ───────────────────────────
# RevenueCat Dashboard -> API Keys -> Secret keys
# Used by /api/premium/status and /api/revenuecat/webhook to fetch subscriber data.

REVENUECAT_SECRET_API_KEY=your-revenuecat-secret-key-here

# Shared secret for the RevenueCat webhook.
# Set this value in RevenueCat Dashboard -> Integrations -> Webhooks
#   -> "Authorization header" field.
# Mirror it here and in Vercel environment variables.

REVENUECAT_WEBHOOK_AUTH=Bearer your-webhook-shared-secret-here
