# ─── Supabase ────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values from your
# Supabase project settings → API tab.
#
# These NEXT_PUBLIC_ values are safe to expose in the browser.
# Row-Level Security policies on your Supabase project protect the data.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── App deep-link scheme ────────────────────────────────────────────────────
# The custom URL scheme registered by the Flutter app.
# Default: valkoda  → opens valkoda://
# Only change this if you update the scheme in the Flutter project.

# NEXT_PUBLIC_APP_SCHEME=valkoda

# ─── Site URL ────────────────────────────────────────────────────────────────
# Set this in Vercel environment variables (not .env.local) so Next.js
# can build correct absolute URLs for metadata and OG images.
#
# NEXT_PUBLIC_SITE_URL=https://valkoda.app
